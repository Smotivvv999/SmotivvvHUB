-- ============================================
-- LOAD RAYFIELD
-- ============================================
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "MARSKIEEE_MMX",
   Icon = 0,
   LoadingTitle = "loading...",
   LoadingSubtitle = "SC QUEST",
   ShowText = "MARSKIEEE.",
   Theme = "Default",

   ToggleUIKeybind = "K",

   DisableRayfieldPrompts = false,
   DisableBuildWarnings = false,

   ConfigurationSaving = {
      Enabled = true,
      FolderName = nil,
      FileName = "BigHub"
   },
})

local Tab = Window:CreateTab("MAIN", "rewind")

-- ============================================
-- SERVICES
-- ============================================
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local gui = player:WaitForChild("PlayerGui")

-- ============================================
-- SETTINGS
-- ============================================
local AutoSapi = false
local KEY_DELAY = 0.007

local FARM_POSITION = Vector3.new(
    -3760.887939,
    -77.642609,
    -23892.484375
)

local SEARCH_RADIUS = 300

-- ============================================
-- PARAGRAPH STATUS
-- ============================================
local Paragraph = Tab:CreateParagraph({
   Title = "STATUS TELEPORT",
   Content = "Menunggu aksi..."
})

local function UpdateParagraph(text)
   Paragraph:Set({
      Title = "STATUS TELEPORT",
      Content = text
   })
end

-- ============================================
-- PRESS KEY
-- ============================================
local function pressKey(key)

    VirtualInputManager:SendKeyEvent(true, key, false, game)

    task.wait(0.01)

    VirtualInputManager:SendKeyEvent(false, key, false, game)
end

-- ============================================
-- EXECUTE SEQUENCE
-- ============================================
local function executeSequence(sequence)

    sequence = sequence:gsub("%s+", "")

    for i = 1, #sequence do

        local letter = sequence:sub(i, i)

        if Enum.KeyCode[letter] then

            pressKey(Enum.KeyCode[letter])

            task.wait(KEY_DELAY)
        end
    end
end

-- ============================================
-- CLEAN TEXT
-- ============================================
local function cleanText(text)

    text = tostring(text)

    text = text:gsub("\n", "")
    text = text:gsub("\r", "")
    text = text:gsub("%s+", "")

    return text
end

-- ============================================
-- TELEPORT FARM
-- ============================================
local function teleportToFarm()

    local character = player.Character
    if not character then return end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    hrp.CFrame = CFrame.new(FARM_POSITION)

    task.wait(1)
end

-- ============================================
-- GET NEAREST COW
-- ============================================
local function GetNearestCow()

    local character = player.Character
    if not character then return end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local nearestPart = nil
    local nearestDistance = math.huge

    for _,obj in ipairs(workspace:GetDescendants()) do

        local name = obj.Name:lower()

        if name:find("sapi") or name:find("cow") then

            local part

            if obj:IsA("BasePart") then
                part = obj
            else
                part = obj:FindFirstChildWhichIsA("BasePart")
            end

            if part then

                local distance =
                    (hrp.Position - part.Position).Magnitude

                local farmDistance =
                    (part.Position - FARM_POSITION).Magnitude

                if distance < nearestDistance
                and farmDistance <= SEARCH_RADIUS then

                    nearestDistance = distance
                    nearestPart = part
                end
            end
        end
    end

    return nearestPart
end

-- ============================================
-- TELEPORT TO COW
-- ============================================
local function moveToCow(cowPart)

    local character = player.Character
    if not character then return false end

    local hrp = character:FindFirstChild("HumanoidRootPart")

    if not hrp or not cowPart then
        return false
    end

    hrp.CFrame =
        CFrame.new(cowPart.Position + Vector3.new(0,0,2))

    return true
end

-- ============================================
-- HANDLE MINIGAME
-- ============================================
local function handleMinigame()

    for _,v in ipairs(gui:GetDescendants()) do

        if not v:IsA("TextLabel") then
            continue
        end

        local text = cleanText(v.Text)

        if text == "" then
            continue
        end

        -- ====================================
        -- MODE URUTAN
        -- ====================================
        if text:find("URUTAN") then

            local result = ""

            for letter in text:gmatch("%u") do

                if Enum.KeyCode[letter] then
                    result = result .. letter
                end
            end

            result = result:gsub("URUTAN", "")

            if #result > 0 then
                executeSequence(result)
            end
        end

        -- ====================================
        -- MODE GASPOL
        -- ====================================
        if text:lower():find("gaspol") then

            local key = text:match("%[([A-Z])%]")
            local amount = tonumber(text:match("x(%d+)"))

            if key and amount and Enum.KeyCode[key] then

                for i = 1, amount do

                    pressKey(Enum.KeyCode[key])

                    task.wait(0.01)
                end
            end
        end

        -- ====================================
        -- MODE PENCET
        -- ====================================
        if text:lower():find("pencet") then

            local key = text:match("%[([A-Z])%]")

            if key and Enum.KeyCode[key] then
                pressKey(Enum.KeyCode[key])
            end
        end
    end
end

-- ============================================
-- START AUTO COW
-- ============================================
local function startAutoCow()

    task.spawn(function()

        teleportToFarm()

        while AutoSapi do

            pcall(function()

                local cow = GetNearestCow()

                if not cow then

                    teleportToFarm()

                    task.wait(1)

                    return
                end

                local success = moveToCow(cow)

                if success then

                    pressKey(Enum.KeyCode.E)

                    task.wait(0.5)

                    local minigameTimeout = tick() + 8

                    while AutoSapi
                    and tick() < minigameTimeout do

                        handleMinigame()

                        task.wait(0.05)
                    end
                end
            end)

            task.wait(0.1)
        end
    end)
end

-- ============================================
-- AUTO OFF IF SIT
-- ============================================
task.spawn(function()

    while true do

        task.wait(0.5)

        if AutoSapi then

            local character = player.Character

            local humanoid =
                character and
                character:FindFirstChildOfClass("Humanoid")

            if humanoid and humanoid.SeatPart then

                AutoSapi = false

                if _G.AutoSapiToggle then
                    _G.AutoSapiToggle:Set(false)
                end

                Rayfield:Notify({
                    Title = "AUTO SAPI OFF",
                    Content = "Kendaraan terdeteksi",
                    Duration = 3,
                    Image = "warning"
                })
            end
        end
    end
end)

-- ============================================
-- AUTO SAPI TOGGLE
-- ============================================
local AutoToggle

AutoToggle = Tab:CreateToggle({
    Name = "AUTO SUSU SAPI",
    CurrentValue = false,
    Flag = "AutoSapiToggle",

    Callback = function(Value)

        AutoSapi = Value

        Rayfield:Notify({
            Title = "AUTO SAPI",
            Content =
                AutoSapi and
                "AUTO SAPI ON" or
                "AUTO SAPI OFF",
            Duration = 3,
            Image = "keyboard"
        })

        if AutoSapi then
            startAutoCow()
        end
    end,
})

_G.AutoSapiToggle = AutoToggle

-- ============================================
-- TELEPORT FUNCTION
-- ============================================
local function Teleport(targetCFrame, placeName)

   local character =
      player.Character or
      player.CharacterAdded:Wait()

   local hrp =
      character:WaitForChild("HumanoidRootPart", 10)

   local humanoid =
      character:WaitForChild("Humanoid", 10)

   if not hrp or not humanoid then
      return
   end

   local seat = humanoid.SeatPart

   local vehicleModel =
      seat and seat:FindFirstAncestorOfClass("Model")

   if vehicleModel and vehicleModel.PrimaryPart then

      local offset =
         vehicleModel.PrimaryPart.CFrame:ToObjectSpace(hrp.CFrame)

      vehicleModel:SetPrimaryPartCFrame(targetCFrame)

      task.wait()

      hrp.CFrame =
         vehicleModel.PrimaryPart.CFrame * offset

   else

      humanoid:ChangeState(
         Enum.HumanoidStateType.GettingUp
      )

      hrp.CFrame = targetCFrame
   end

   hrp.AssemblyLinearVelocity = Vector3.zero
   hrp.AssemblyAngularVelocity = Vector3.zero

   Rayfield:Notify({
      Title = "Teleport",
      Content = "Berhasil teleport ke "..placeName,
      Duration = 2,
      Image = "map-pinned"
   })
end

-- ============================================
-- COUNTDOWN
-- ============================================
local function Countdown(seconds, label)

   for i = seconds, 1, -1 do

      local progress = (seconds - i) / seconds

      local barLength = 20

      local filled =
         math.floor(progress * barLength)

      local bar =
         string.rep("█", filled) ..
         string.rep("░", barLength - filled)

      UpdateParagraph(
         label ..
         "\n[" .. bar .. "] " ..
         math.floor(progress * 100) ..
         "% (" .. i .. "s)"
      )

      task.wait(1)
   end
end

