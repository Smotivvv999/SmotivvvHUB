-- ============================================
-- AUTO DETECT MASJID
-- ============================================
local AutoMasjid = false
local LastTarget = nil
local Running = false

Tab:CreateToggle({
   Name = "AUTO MASJID",
   CurrentValue = false,
   Flag = "AutoMasjid",

   Callback = function(Value)

      AutoMasjid = Value

      Rayfield:Notify({
         Title = "AUTO MASJID",
         Content =
            AutoMasjid and
            "AUTO MASJID ON" or
            "AUTO MASJID OFF",
         Duration = 3,
         Image = "map"
      })
   end
})

task.spawn(function()

   while task.wait(0.5) do

      if not AutoMasjid then
         continue
      end

      if Running then
         continue
      end

      local WaypointFolder =
         workspace:FindFirstChild("Etc")

      local WaypointMain =
         WaypointFolder and
         WaypointFolder:FindFirstChild("Waypoint")

      local Waypoint =
         WaypointMain and
         WaypointMain:FindFirstChild("Waypoint")

      local Billboard =
         Waypoint and
         Waypoint:FindFirstChild("BillboardGui")

      local Label =
         Billboard and
         Billboard:FindFirstChild("TextLabel")

      if Label then

         local text = tostring(Label.Text)

         UpdateParagraph(
            "Tujuan Terdeteksi : "..text
         )

         for key,data in pairs(MasjidList) do

            if string.find(text, key) then

               if LastTarget ~= data.Name then

                  Running = true
                  LastTarget = data.Name

                  UpdateParagraph(
                     "Tujuan ditemukan : "..data.Name
                  )

                  Countdown(
                     data.Delay,
                     "Menuju "..data.Name
                  )

                  UpdateParagraph(
                     "Teleport ke "..data.Name.."..."
                  )

                  Teleport(
                     data.CFrame,
                     data.Name
                  )

                  UpdateParagraph(
                     "Sudah sampai "..data.Name.." ✔"
                  )

                  task.wait(3)

                  Running = false
               end
            end
         end
      end
   end
end)

