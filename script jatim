-- ============================================
-- PRESS KEY
-- ============================================
local function pressKey(key)

    VirtualInputManager:SendKeyEvent(true, key, false, game)

    task.wait(0.01)

    VirtualInputManager:SendKeyEvent(false, key, false, game)
end

-- ============================================
-- EXECUTE SEQUENCE
-- ============================================
local function executeSequence(sequence)

    sequence = sequence:gsub("%s+", "")

    for i = 1, #sequence do

        local letter = sequence:sub(i, i)

        if Enum.KeyCode[letter] then

            pressKey(Enum.KeyCode[letter])

            task.wait(KEY_DELAY)
        end
    end
end

-- ============================================
-- CLEAN TEXT
-- ============================================
local function cleanText(text)

    text = tostring(text)

    text = text:gsub("\n", "")
    text = text:gsub("\r", "")
    text = text:gsub("%s+", "")

    return text
end

-- ============================================
-- TELEPORT FARM
-- ============================================
local function teleportToFarm()

    local character = player.Character
    if not character then return end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    hrp.CFrame = CFrame.new(FARM_POSITION)

    task.wait(1)
end

-- ============================================
-- COW CACHE
-- ============================================
local CowCache = {}
local LastCowScan = 0

-- ============================================
-- CACHE COWS
-- ============================================
local function RefreshCowCache()

    table.clear(CowCache)

    for _,obj in ipairs(workspace:GetDescendants()) do

        local name =
            tostring(obj.Name):lower()

        if name:find("sapi")
        or name:find("cow") then

            local part

            if obj:IsA("BasePart") then
                part = obj
            else
                part =
                    obj:FindFirstChildWhichIsA("BasePart")
            end

            if part then
                table.insert(CowCache, part)
            end
        end
    end
end

-- ============================================
-- GET NEAREST COW
-- ============================================
local function GetNearestCow()

    local character = player.Character
    if not character then
        return nil
    end

    local hrp =
        character:FindFirstChild("HumanoidRootPart")

    if not hrp then
        return nil
    end

    -- refresh cache tiap 5 detik
    if tick() - LastCowScan > 5 then

        LastCowScan = tick()

        RefreshCowCache()
    end

    local nearestPart = nil
    local nearestDistance = math.huge

    for _,part in ipairs(CowCache) do

        if part and part.Parent then

            local distance =
                (hrp.Position - part.Position).Magnitude

            local farmDistance =
                (part.Position - FARM_POSITION).Magnitude

            if distance < nearestDistance
            and farmDistance <= SEARCH_RADIUS then

                nearestDistance = distance
                nearestPart = part
            end
        end
    end

    return nearestPart
end

-- ============================================
-- MOVE TO COW (ANTI GOYANG)
-- ============================================
local function moveToCow(cowPart)

    local character = player.Character
    if not character then
        return false
    end

    local hrp =
        character:FindFirstChild("HumanoidRootPart")

    if not hrp or not cowPart then
        return false
    end

    -- posisi stabil
    local targetPos =
        cowPart.Position +
        Vector3.new(0,0,2.5)

    -- jangan teleport terus
    local distance =
        (hrp.Position - targetPos).Magnitude

    if distance > 4 then

        hrp.CFrame =
            CFrame.new(
                targetPos,
                cowPart.Position
            )

        hrp.AssemblyLinearVelocity =
            Vector3.zero

        hrp.AssemblyAngularVelocity =
            Vector3.zero
    end

    return true
end

-- ============================================
-- MINIGAME CACHE
-- ============================================
local LastMinigameText = ""
local LastMinigameTick = 0

-- ============================================
-- MINIGAME OPTIMIZED
-- ============================================
local LastText = {}
local LastPress = 0

-- ============================================
-- SAFE PRESS
-- ============================================
local function safePress(key)

    local now = tick()

    -- anti spam terlalu cepat
    if now - LastPress < 0.015 then
        return
    end

    LastPress = now

    pressKey(key)
end

-- ============================================
-- HANDLE MINIGAME OPTIMIZED
-- ============================================
local function handleMinigame()

    local labels = gui:GetDescendants()

    for i = 1, #labels do

        local v = labels[i]

        if not v:IsA("TextLabel") then
            continue
        end

        if not v.Visible then
            continue
        end

        local raw = v.Text

        if raw == "" then
            continue
        end

        local text =
            cleanText(raw)

        if text == "" then
            continue
        end

        -- ====================================
        -- ANTI REPROCESS
        -- ====================================
        if LastText[text]
        and tick() - LastText[text] < 0.15 then
            continue
        end

        LastText[text] = tick()

        -- ====================================
        -- MODE URUTAN
        -- ====================================
        if text:find("URUTAN") then

            local result = ""

            for letter in text:gmatch("%u") do

                if Enum.KeyCode[letter] then
                    result = result .. letter
                end
            end

            result =
                result:gsub("URUTAN", "")

            if #result > 0 then

                for x = 1, #result do

                    local key =
                        result:sub(x, x)

                    if Enum.KeyCode[key] then

                        safePress(
                            Enum.KeyCode[key]
                        )

                        task.wait(0.01)
                    end
                end
            end
        end

        -- ====================================
        -- MODE GASPOL
        -- ====================================
        if text:lower():find("gaspol") then

            local key =
                text:match("%[([A-Z])%]")

            local amount =
                tonumber(
                    text:match("x(%d+)")
                )

            if key
            and amount
            and Enum.KeyCode[key] then

                -- cap biar gak freeze
                amount =
                    math.clamp(amount, 1, 30)

                for x = 1, amount do

                    safePress(
                        Enum.KeyCode[key]
                    )

                    task.wait(0.01)
                end
            end
        end

        -- ====================================
        -- MODE PENCET
        -- ====================================
        if text:lower():find("pencet") then

            local key =
                text:match("%[([A-Z])%]")

            if key
            and Enum.KeyCode[key] then

                safePress(
                    Enum.KeyCode[key]
                )
            end
        end
    end

    -- bersihin cache lama
    for txt,time in pairs(LastText) do

        if tick() - time > 2 then
            LastText[txt] = nil
        end
    end
end

-- ============================================
-- START AUTO COW
-- ============================================
local function startAutoCow()

    task.spawn(function()

        teleportToFarm()

        task.wait(1)

        while AutoSapi do

            pcall(function()

                local cow =
                    GetNearestCow()

                if not cow then

                    UpdateParagraph(
                        "Mencari sapi..."
                    )

                    task.wait(1)

                    return
                end

                local success =
                    moveToCow(cow)

                if success then

                    task.wait(0.2)

                    pressKey(
                        Enum.KeyCode.E
                    )

                    task.wait(0.8)

                    local minigameTimeout =
                        tick() + 8

                    while AutoSapi
                    and tick() < minigameTimeout do

                        handleMinigame()

                        -- lebih ringan
                        task.wait(0.15)
                    end
                end
            end)

            task.wait(0.3)
        end
    end)
end

