-- ============================================
-- MAIN LOOP
-- ============================================
task.spawn(function()

    while task.wait(1) do

        if not AutoMasjid then
            continue
        end

        if Running then
            continue
        end

        local target = GetMasjidTarget()

        -- ====================================
        -- TARGET DITEMUKAN
        -- ====================================
        if target then

            -- anti spam
            if Cooldown then
                continue
            end

            Cooldown = true
            Running = true

            -- matikan auto sapi sementara
            if AutoSapi then
                AutoSapi = false

                if _G.AutoSapiToggle then
                    _G.AutoSapiToggle:Set(false)
                end
            end

            UpdateParagraph(
                "TARGET : " .. target.Name ..
                "\nTeleport " .. target.Delay .. " detik..."
            )

            -- COUNTDOWN
            Countdown(
                target.Delay,
                "MENUJU " .. target.Name
            )

            -- TELEPORT
            Teleport(
                target.CFrame,
                target.Name
            )

            UpdateParagraph(
                "SAMPAI " .. target.Name ..
                " ✔\nMENGAKTIFKAN AUTO SAPI..."
            )

            -- tunggu stabil dulu
            task.wait(2)

            -- cek jangan aktif kalau duduk
            local character = player.Character

            local humanoid =
                character and
                character:FindFirstChildOfClass("Humanoid")

            local sitting =
                humanoid and humanoid.SeatPart

            -- aktifkan lagi auto sapi
            if not sitting then

                AutoSapi = true

                if _G.AutoSapiToggle then
                    _G.AutoSapiToggle:Set(true)
                end

                -- start ulang loop sapi
                startAutoCow()

                Rayfield:Notify({
                    Title = "AUTO SAPI",
                    Content = "AUTO SUSU SAPI AKTIF",
                    Duration = 3,
                    Image = "cow"
                })

            else

                Rayfield:Notify({
                    Title = "AUTO SAPI",
                    Content = "Gagal aktif, karakter sedang duduk",
                    Duration = 3,
                    Image = "warning"
                })
            end

            task.wait(2)

            Running = false

        else

            -- reset kalau quest hilang
            Cooldown = false

            UpdateParagraph(
                "Menunggu perintah..."
            )
        end
    end
end)

