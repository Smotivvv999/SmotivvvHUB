-- ============================================
-- TELEPORT FUNCTION
-- ============================================
local function Teleport(targetCFrame, placeName)

    local character =
        player.Character or
        player.CharacterAdded:Wait()

    local hrp =
        character:WaitForChild("HumanoidRootPart", 10)

    local humanoid =
        character:WaitForChild("Humanoid", 10)

    if not hrp or not humanoid then
        return
    end

    local seat = humanoid.SeatPart

    local vehicleModel =
        seat and seat:FindFirstAncestorOfClass("Model")

    if vehicleModel and vehicleModel.PrimaryPart then

        local offset =
            vehicleModel.PrimaryPart.CFrame:ToObjectSpace(hrp.CFrame)

        vehicleModel:SetPrimaryPartCFrame(targetCFrame)

        task.wait()

        hrp.CFrame =
            vehicleModel.PrimaryPart.CFrame * offset

    else

        humanoid:ChangeState(
            Enum.HumanoidStateType.GettingUp
        )

        hrp.CFrame = targetCFrame
    end

    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    Rayfield:Notify({
        Title = "Teleport",
        Content = "Berhasil teleport ke " .. placeName,
        Duration = 2,
        Image = "map-pinned"
    })
end

-- ============================================
-- COUNTDOWN
-- ============================================
local function Countdown(seconds, label)

    for i = seconds, 1, -1 do

        local progress = (seconds - i) / seconds

        local barLength = 20

        local filled =
            math.floor(progress * barLength)

        local bar =
            string.rep("█", filled) ..
            string.rep("░", barLength - filled)

        UpdateParagraph(
            label ..
            "\n[" .. bar .. "] " ..
            math.floor(progress * 100) ..
            "% (" .. i .. "s)"
        )

        task.wait(1)
    end
end

-- ============================================
-- AUTO DETECT MASJID FINAL FIX
-- ============================================
local AutoMasjid = false
local Running = false
local Cooldown = false

-- ============================================
-- GET TARGET
-- ============================================
local function GetMasjidTarget()

    local masjidDetected = false
    local studsText = ""

    -- scan PlayerGui saja (lebih ringan)
    for _,v in ipairs(player.PlayerGui:GetDescendants()) do

        if v:IsA("TextLabel") then

            local text =
                tostring(v.Text):lower()

            -- detect masjid
            if text:find("masjid") then
                masjidDetected = true
            end

            -- detect studs
            if text:find("studs") then
                studsText = text
            end
        end
    end

    -- tidak ada tujuan
    if not masjidDetected then
        return nil
    end

    -- DEBUG STATUS
    UpdateParagraph(
        "MASJID TERDETEKSI\n"..
        "DISTANCE : "..studsText
    )

    -- ====================================
    -- MASJID 3K
    -- ====================================
    if studsText:find("3%.0k") then

        return {
            Name = "MASJID 3K",
            Delay = 15,

            CFrame = CFrame.new(
                -4035.952148,
                -79.151535,
                -26729.810547
            )
        }
    end

    -- ====================================
    -- MASJID 9K
    -- ====================================
    if studsText:find("9%.3k") then

        return {
            Name = "MASJID 9K",
            Delay = 25,

            CFrame = CFrame.new(
                -2842.638672,
                -38.547020,
                -14443.070312
            )
        }
    end

    -- ====================================
    -- MASJID 23K
    -- ====================================
    if studsText:find("23%.8k") then

        return {
            Name = "MASJID 23K",
            Delay = 55,

            CFrame = CFrame.new(
                60.027203,
                3.475821,
                -225.967621
            )
        }
    end

    return nil
end

